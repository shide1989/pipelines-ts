{
  "name": "pipelines-ts",
  "version": "0.5.1",
  "description": "Durable workflow runtime with replayable, idempotent steps.",
  "license": "MIT",
  "author": "Sebastien Hideux",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shide1989/pipelines-ts.git"
  },
  "keywords": [
    "workflow",
    "durable",
    "runtime",
    "pipelines",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schema.sql"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-esm-fix --tsconfig tsconfig.build.json",
    "bench": "bun run bench/bench.ts",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "postgres": "^3.4.9",
    "tsc-esm-fix": "^3.1.2"
  }
}
